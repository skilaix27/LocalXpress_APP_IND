# ==================================================
# LocalXpress APP-IND — Variables de entorno
# Copia este archivo como .env y rellena los valores.
# Nunca commitees .env con valores reales.
# ==================================================

# ── Server ─────────────────────────────────────────
# Desarrollo local:
PORT=3001
# Producción VPS (escucha solo en loopback, Nginx hace proxy):
# PORT=3002
# HOST=127.0.0.1

NODE_ENV=development
# Producción: NODE_ENV=production

# ── URLs de la app ─────────────────────────────────
# Desarrollo:
FRONTEND_URL=http://localhost:8080
# Producción:
# FRONTEND_URL=https://localxpress.es

# ── Frontend Vite ──────────────────────────────────
# Desarrollo:
VITE_API_URL=http://localhost:3001
# Producción (debe apuntar al backend HTTPS público):
# VITE_API_URL=https://api-recogida.localxpress.es

# ── Google Maps ────────────────────────────────────
# Backend key (server-side only — nunca exponer en frontend)
GOOGLE_MAPS_API_KEY=

# Frontend browser key (HTTP referrer restricted en Google Cloud Console)
VITE_GOOGLE_MAPS_BROWSER_KEY=

# ── Stripe ─────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe redirect URLs
# Desarrollo:
PUBLIC_APP_SUCCESS_URL=http://localhost:8080/success
PUBLIC_APP_CANCEL_URL=http://localhost:8080/cancel
# Producción:
# PUBLIC_APP_SUCCESS_URL=https://localxpress.es/solicitar-recogida/formulario/success
# PUBLIC_APP_CANCEL_URL=https://localxpress.es/solicitar-recogida/formulario/cancel

# ── Email — Resend (resend.com) ────────────────────
RESEND_API_KEY=
RESEND_FROM="LocalXpress <no-reply@localxpress.app>"
ADMIN_EMAIL=

# ── Soporte ────────────────────────────────────────
LOCALXPRESS_SUPPORT_PHONE="+34 711-22-57-93"

# ── App central LocalXpress (backend only) ─────────
LOCALXPRESS_CENTRAL_API_URL=https://api.localxpress.app
LOCALXPRESS_CENTRAL_API_KEY=

# ── Emails locales ─────────────────────────────────
# Por defecto false: la app central gestiona todas las notificaciones.
# Poner "true" solo para testing o si la app central no está disponible.
SEND_LOCAL_EMAILS=false

# ── Logging ────────────────────────────────────────
# Poner "debug" para activar logs detallados con PII (solo desarrollo).
# En producción dejar vacío o no definir.
# LOG_LEVEL=debug
