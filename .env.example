# Frontend
VITE_API_URL=http://localhost:3001

# Backend
PORT=3001
FRONTEND_URL=http://localhost:5173

# Google Maps backend key (server-side only — never expose in frontend)
GOOGLE_MAPS_API_KEY=

# Google Maps browser key (frontend autocomplete — HTTP referrer restricted)
VITE_GOOGLE_MAPS_BROWSER_KEY=

# Stripe test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe redirect URLs
PUBLIC_APP_SUCCESS_URL=http://localhost:8080/success
PUBLIC_APP_CANCEL_URL=http://localhost:8080/cancel

# Email — Resend (resend.com)
RESEND_API_KEY=
RESEND_FROM="LocalXpress <no-reply@localxpress.app>"
ADMIN_EMAIL=
LOCALXPRESS_SUPPORT_PHONE="+34 711-22-57-93"

# SMTP (legacy — no longer used in this flow)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Central LocalXpress backend (server-side only — never expose in frontend)
LOCALXPRESS_CENTRAL_API_URL=https://api.localxpress.app
LOCALXPRESS_CENTRAL_API_KEY=

# Local email sending (default: false)
# By default the central LocalXpress app handles all customer and admin notifications.
# Set to "true" only for testing or as backup when the central app is unavailable.
SEND_LOCAL_EMAILS=false
